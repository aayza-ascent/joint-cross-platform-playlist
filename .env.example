# --- App ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Neon) ---
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Token vault (libsodium secretbox, 32 bytes base64) ---
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# --- Auth.js Google provider (app login) ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- YouTube provider connect (separate Google OAuth client) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Spotify provider connect ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
